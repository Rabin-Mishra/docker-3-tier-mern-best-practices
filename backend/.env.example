# Server Config
PORT=5000
NODE_ENV=development

# Database Config
MONGO_URI=mongodb://localhost:27017/mern_db

# JWT Config (Expiration in seconds or standard vercel format, e.g. 24h, 1d)
JWT_SECRET=supersecretsomewhereinuniverse
JWT_EXPIRES_IN=24h

# Logs Config
# Local development fallback path
LOG_DIR=./logs
# Inside Docker containers, this is mounted to a volume at: /data/logs
# LOG_DIR=/data/logs

# Seeding configurations
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123
SEED_USER_EMAIL=user@example.com
SEED_USER_PASSWORD=user123

# CORS Config (Frontend URL)
CLIENT_URL=http://localhost:5173
